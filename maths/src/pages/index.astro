---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Maths">
  <main>
    <h1>Apprends les Maths avec <span class="name" id="child-name"></span></h1>
    <nav>
      <a href={`${import.meta.env.BASE_URL}vases`} class="card">
        <span class="icon">🧪</span>
        <span class="label">Les vases</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}balance`} class="card">
        <span class="icon">⚖️</span>
        <span class="label">La balance</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}doubles`} class="card">
        <span class="icon">🧮</span>
        <span class="label">Les doubles</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}astuce`} class="card">
        <span class="icon">💡</span>
        <span class="label">L'exercice</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}palmares`} class="card">
        <span class="icon">🏆</span>
        <span class="label">Palmares</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}settings`} class="card">
        <span class="icon">⚙️</span>
        <span class="label">Réglages</span>
      </a>
    </nav>
  </main>
</Layout>

<style>
  main {
    text-align: center;
    padding: 2rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 2rem;
    color: #7c3aed;
  }

  .name {
    cursor: pointer;
    border-bottom: 2px dashed #a78bfa;
    transition: border-color 0.15s;
  }

  .name:hover {
    border-color: #7c3aed;
  }

  nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 300px;
    margin: 0 auto;
  }

  .card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    background: white;
    border-radius: 1rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    text-decoration: none;
    color: #1a1a2e;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.12);
  }

  .icon {
    font-size: 2rem;
  }

  .label {
    font-size: 1.3rem;
    font-weight: 600;
  }
</style>

<script>
  const nameEl = document.getElementById('child-name')!;

  function askName() {
    const name = prompt('Comment tu t\u2019appelles ?')?.trim();
    if (name) {
      localStorage.setItem('maths-child-name', name);
      nameEl.textContent = name;
    }
    return name;
  }

  const saved = localStorage.getItem('maths-child-name');
  if (saved) {
    nameEl.textContent = saved;
  } else {
    askName();
  }

  nameEl.addEventListener('click', askName);
</script>
