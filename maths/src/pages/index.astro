---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Maths avec Estelle">
  <main>
    <h1>Maths avec Estelle</h1>
    <nav>
      <a href={`${import.meta.env.BASE_URL}vases`} class="card">
        <span class="icon">🧪</span>
        <span class="label">Les vases</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}balance`} class="card">
        <span class="icon">⚖️</span>
        <span class="label">La balance</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}doubles`} class="card">
        <span class="icon">🧮</span>
        <span class="label">Les doubles</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}astuce`} class="card">
        <span class="icon">💡</span>
        <span class="label">L'exercice</span>
      </a>
    </nav>
  </main>
</Layout>

<style>
  main {
    text-align: center;
    padding: 2rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 2rem;
    color: #7c3aed;
  }

  nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 300px;
    margin: 0 auto;
  }

  .card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    background: white;
    border-radius: 1rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    text-decoration: none;
    color: #1a1a2e;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.12);
  }

  .icon {
    font-size: 2rem;
  }

  .label {
    font-size: 1.3rem;
    font-weight: 600;
  }
</style>
