---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Les doubles">
  <main>
    <a href={import.meta.env.BASE_URL} class="back">←</a>

    <div class="exercise">
      <div class="difficulty">
        <label for="difficulty">Difficulté : <span id="diff-val">10</span></label>
        <input type="range" id="difficulty" min="10" max="50" value="10" step="10" />
      </div>

      <div class="dots-row">
        <div class="dots-group" id="dots-left"></div>
        <div class="dots-group" id="dots-right"></div>
      </div>

      <div class="equation">
        <span class="number" id="num-left">3</span>
        <span class="operator">+</span>
        <span class="number" id="num-right">3</span>
        <span class="operator">=</span>
        <input
          type="number"
          id="answer"
          inputmode="none"
          autocomplete="off"
          placeholder="?"
        />
      </div>

      <div class="numpad">
        <button class="numkey" data-key="1">1</button>
        <button class="numkey" data-key="2">2</button>
        <button class="numkey" data-key="3">3</button>
        <button class="numkey" data-key="4">4</button>
        <button class="numkey" data-key="5">5</button>
        <button class="numkey" data-key="6">6</button>
        <button class="numkey" data-key="7">7</button>
        <button class="numkey" data-key="8">8</button>
        <button class="numkey" data-key="9">9</button>
        <button class="numkey del" data-key="del">←</button>
        <button class="numkey" data-key="0">0</button>
        <button class="numkey ok" data-key="ok">OK</button>
      </div>

      <div class="status-bar">
        <div class="streak-col">
          <div class="streak-info">
            <span class="streak-flame" id="flame">🔥</span>
            <span class="streak-count" id="streak">0</span>
          </div>
          <div class="stars" id="stars"></div>
        </div>
        <button id="next" class="next-btn hidden">Suivant ▶</button>
      </div>

    </div>
  </main>
  <div class="toast" id="toast"></div>
  <div class="pusheen-popup" id="pusheen-popup"></div>
</Layout>

<style>
  main {
    text-align: center;
    padding: 1rem;
    width: 100%;
    max-width: 500px;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  .status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.8rem;
    min-height: 48px;
  }

  .streak-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }

  .streak-info {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #7c3aed;
  }

  .streak-flame {
    font-size: 1.4rem;
    transition: transform 0.3s;
  }

  .streak-flame.hot {
    animation: flame-pulse 0.5s ease;
  }

  @keyframes flame-pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.5); }
    100% { transform: scale(1); }
  }

  .streak-count {
    font-size: 1.4rem;
    min-width: 1.5ch;
  }

  .stars {
    font-size: 1.2rem;
    letter-spacing: 1px;
  }

  .difficulty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 1rem;
  }

  .difficulty label {
    font-size: 0.8rem;
    font-weight: 700;
    color: #7c3aed;
  }

  .difficulty input[type="range"] {
    width: 100%;
    accent-color: #7c3aed;
  }

  .exercise {
    background: white;
    border-radius: 1.5rem;
    padding: 2rem 1.5rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .dots-row {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
    min-height: 80px;
    align-items: center;
  }

  .dots-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: flex-start;
    max-width: 140px;
  }

  .dots-group :global(.dot-group) {
    display: flex;
    gap: 4px;
  }

  .dots-group :global(.dot) {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: inline-block;
  }

  .dots-group:first-child :global(.dot) {
    background: #f472b6;
  }

  .dots-group:last-child :global(.dot) {
    background: #818cf8;
  }

  .equation {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .number {
    font-size: 2.8rem;
    font-weight: 700;
    color: #1a1a2e;
    min-width: 2ch;
  }

  .number :global(ruby) { ruby-align: center; }
  .number :global(rt) { font-size: 0.35em; font-weight: 600; }
  .number :global(.rt-d) { color: #f59e0b; }
  .number :global(.rt-u) { color: #7c3aed; }

  .operator {
    font-size: 2.8rem;
    font-weight: 400;
    color: #7c3aed;
  }

  input {
    font-size: 2.8rem;
    font-weight: 700;
    width: 3ch;
    text-align: center;
    border: 3px solid #e0e0e0;
    border-radius: 0.8rem;
    padding: 0;
    line-height: 1;
    vertical-align: middle;
    font-family: inherit;
    margin-top: 0.45rem;
    color: #1a1a2e;
    background: #fef7ff;
    outline: none;
    transition: border-color 0.2s;
  }

  input:focus {
    border-color: #7c3aed;
  }

  input::placeholder {
    color: #ccc;
  }

  input::-webkit-outer-spin-button,
  input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input[type=number] {
    -moz-appearance: textfield;
  }

  .next-btn {
    font-size: 1.2rem;
    font-weight: 700;
    padding: 0.6rem 1.5rem;
    border: none;
    border-radius: 0.8rem;
    background: #16a34a;
    color: white;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }

  .next-btn:hover { background: #15803d; }
  .next-btn:active { transform: scale(0.97); }

  .numpad {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    max-width: 280px;
    margin: 1rem auto;
  }

  .numkey {
    font-size: 1.6rem;
    font-weight: 700;
    padding: 0.7rem;
    border: 2px solid #e0e0e0;
    border-radius: 0.8rem;
    background: #fef7ff;
    color: #1a1a2e;
    cursor: pointer;
    transition: background 0.1s, transform 0.1s;
  }

  .numkey:active {
    transform: scale(0.95);
    background: #ede9fe;
  }

  .numkey.del {
    background: #fee2e2;
    color: #dc2626;
    border-color: #fca5a5;
  }

  .numkey.ok {
    background: #7c3aed;
    color: white;
    border-color: #7c3aed;
  }

  .numkey.ok:active {
    background: #6d28d9;
  }

  .hidden {
    visibility: hidden;
  }

  .toast {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    font-size: 4rem;
    font-weight: 900;
    padding: 0.6rem 2.5rem;
    border-radius: 1.5rem;
    pointer-events: none;
    z-index: 9998;
    opacity: 0;
    text-shadow: 0 4px 12px rgba(0,0,0,0.15);
    letter-spacing: 2px;
  }

  .toast.show {
    animation: toast-pop 1.8s cubic-bezier(.17,.67,.35,1.2) forwards;
  }

  @keyframes toast-pop {
    0% { transform: translate(-50%, -50%) scale(0) rotate(-8deg); opacity: 0; }
    12% { transform: translate(-50%, -50%) scale(1.4) rotate(3deg); opacity: 1; }
    20% { transform: translate(-50%, -50%) scale(0.9) rotate(-2deg); }
    28% { transform: translate(-50%, -50%) scale(1.15) rotate(1deg); }
    36% { transform: translate(-50%, -50%) scale(1) rotate(0deg); }
    70% { transform: translate(-50%, -50%) scale(1) rotate(0deg); opacity: 1; }
    100% { transform: translate(-50%, -70%) scale(1.3) rotate(0deg); opacity: 0; }
  }

  .pusheen-popup {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    z-index: 9997;
    pointer-events: none;
    opacity: 0;
    filter: drop-shadow(0 4px 20px rgba(124, 58, 237, 0.3));
  }

  .pusheen-popup :global(img) {
    max-height: 160px;
    border-radius: 1rem;
  }

  .pusheen-popup.show {
    animation: pusheen-pop 3s cubic-bezier(.17,.67,.35,1.2) forwards;
  }

  @keyframes pusheen-pop {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
    10% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
    18% { transform: translate(-50%, -50%) scale(0.95); }
    25% { transform: translate(-50%, -50%) scale(1); }
    75% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    100% { transform: translate(-50%, -60%) scale(0.8); opacity: 0; }
  }
</style>

<script>
  import { showPusheen } from '../pusheen';

  const pusheenPopup = document.getElementById('pusheen-popup')!;

  function confetti() {
    const colors = ['#f472b6', '#818cf8', '#7c3aed', '#16a34a', '#facc15', '#fb923c'];
    const count = 80;
    for (let i = 0; i < count; i++) {
      const el = document.createElement('div');
      const size = Math.random() * 8 + 4;
      el.style.cssText = `
        position:fixed;z-index:9999;pointer-events:none;
        width:${size}px;height:${size}px;
        background:${colors[Math.floor(Math.random() * colors.length)]};
        border-radius:${Math.random() > 0.5 ? '50%' : '2px'};
        left:${Math.random() * 100}vw;top:-10px;
        opacity:1;
      `;
      document.body.appendChild(el);
      const x = (Math.random() - 0.5) * 200;
      const y = Math.random() * 600 + 400;
      const r = Math.random() * 720 - 360;
      const dur = Math.random() * 1000 + 1500;
      el.animate([
        { transform: 'translate(0,0) rotate(0deg)', opacity: 1 },
        { opacity: 1, offset: 0.7 },
        { transform: `translate(${x}px,${y}px) rotate(${r}deg)`, opacity: 0 },
      ], { duration: dur, easing: 'cubic-bezier(.25,.46,.45,.94)' })
        .onfinish = () => el.remove();
    }
  }

  function buildDoubles(max: number) {
    return Array.from({ length: max }, (_, i) => [i + 1, i + 1] as [number, number]);
  }

  const diffSlider = document.getElementById('difficulty') as HTMLInputElement;
  const diffVal = document.getElementById('diff-val')!;
  let doubles = buildDoubles(parseInt(diffSlider.value, 10));

  const numLeft = document.getElementById('num-left')!;
  const numRight = document.getElementById('num-right')!;
  const dotsLeft = document.getElementById('dots-left')!;
  const dotsRight = document.getElementById('dots-right')!;
  const answer = document.getElementById('answer') as HTMLInputElement;
  const numpad = document.querySelectorAll('.numkey');
  const nextBtn = document.getElementById('next')!;
  const toast = document.getElementById('toast')!;

  function showToast(text: string, color: string) {
    toast.textContent = text;
    toast.style.color = color;
    toast.classList.remove('show');
    void toast.offsetWidth;
    toast.classList.add('show');
  }
  const streakEl = document.getElementById('streak')!;
  const starsEl = document.getElementById('stars')!;
  const flameEl = document.getElementById('flame')!;

  let current: [number, number];
  let lastIndex = -1;
  let streak = 0;
  let sessionStars = 0;
  const COOLDOWN_MASTERED = 3;
  const COOLDOWN_FAILED = 1;
  const MASTERY_THRESHOLD = 3;
  let staleThreshold = doubles.length;
  let tracker = doubles.map(() => ({ correctStreak: 0, cooldown: 0, lastSeen: 0 }));
  let pickCount = 0;

  let diffTimeout: ReturnType<typeof setTimeout>;
  diffSlider.addEventListener('input', () => {
    diffVal.textContent = diffSlider.value;
    clearTimeout(diffTimeout);
    diffTimeout = setTimeout(() => {
      const max = parseInt(diffSlider.value, 10);
      doubles = buildDoubles(max);
      staleThreshold = doubles.length;
      tracker = doubles.map(() => ({ correctStreak: 0, cooldown: 0, lastSeen: 0 }));
      pickCount = 0;
      lastIndex = -1;
      nextExercise();
    }, 300);
  });

  function updateStars() {
    starsEl.textContent = Array(sessionStars).fill('\u2B50').join('');
  }

  function saveBest(game: string, streak: number, stars: number) {
    const data = JSON.parse(localStorage.getItem('maths-data') || '{}');
    if (!data[game]) data[game] = { bestStreak: 0, totalStars: 0, sessions: [] };
    const g = data[game];
    if (streak > g.bestStreak) g.bestStreak = streak;
    g.totalStars += stars;
    g.sessions.unshift({ streak, stars, date: new Date().toISOString() });
    if (g.sessions.length > 20) g.sessions.length = 20;
    localStorage.setItem('maths-data', JSON.stringify(data));
  }

  function renderNumber(el: HTMLElement, n: number) {
    if (n < 10) {
      el.innerHTML = `<ruby>${n}<rt class="rt-u">u</rt></ruby>`;
    } else {
      const d = Math.floor(n / 10);
      const u = n % 10;
      el.innerHTML = `<ruby>${d}<rt class="rt-d">d</rt></ruby><ruby>${u}<rt class="rt-u">u</rt></ruby>`;
    }
  }

  function renderDots(container: HTMLElement, count: number) {
    container.innerHTML = '';
    const fullGroups = Math.floor(count / 5);
    const remainder = count % 5;
    for (let g = 0; g < fullGroups; g++) {
      const group = document.createElement('span');
      group.className = 'dot-group';
      for (let i = 0; i < 5; i++) {
        const dot = document.createElement('span');
        dot.className = 'dot';
        group.appendChild(dot);
      }
      container.appendChild(group);
    }
    if (remainder > 0) {
      const group = document.createElement('span');
      group.className = 'dot-group';
      for (let i = 0; i < remainder; i++) {
        const dot = document.createElement('span');
        dot.className = 'dot';
        group.appendChild(dot);
      }
      container.appendChild(group);
    }
  }

  function pickRandom() {
    pickCount++;
    let staleIdx = -1;
    let stalestAge = 0;
    for (let i = 0; i < doubles.length; i++) {
      const age = pickCount - tracker[i].lastSeen;
      if (i !== lastIndex && age > staleThreshold && age > stalestAge) {
        stalestAge = age;
        staleIdx = i;
      }
    }
    if (staleIdx !== -1) {
      tracker[staleIdx].cooldown = 0;
      lastIndex = staleIdx;
      tracker[staleIdx].lastSeen = pickCount;
      tracker.forEach(t => { if (t.cooldown > 0) t.cooldown--; });
      return doubles[staleIdx];
    }
    let eligible = [];
    for (let i = 0; i < doubles.length; i++) {
      if (tracker[i].cooldown === 0 && i !== lastIndex) eligible.push(i);
    }
    if (eligible.length === 0) {
      for (let i = 0; i < doubles.length; i++) {
        if (i !== lastIndex) eligible.push(i);
      }
    }
    const idx = eligible[Math.floor(Math.random() * eligible.length)];
    lastIndex = idx;
    tracker[idx].lastSeen = pickCount;
    tracker.forEach(t => { if (t.cooldown > 0) t.cooldown--; });
    return doubles[idx];
  }

  function nextExercise() {
    current = pickRandom() as [number, number];
    renderNumber(numLeft, current[0]);
    renderNumber(numRight, current[1]);
    renderDots(dotsLeft, current[0]);
    renderDots(dotsRight, current[1]);
    answer.value = '';
    answer.style.borderColor = '';
    answer.disabled = false;
    nextBtn.classList.add('hidden');
    answer.focus();
  }

  function check() {
    const val = parseInt(answer.value, 10);
    const expected = current[0] + current[1];

    if (isNaN(val)) {
      answer.focus();
      return;
    }

    if (val === expected) {
      tracker[lastIndex].correctStreak++;
      if (tracker[lastIndex].correctStreak >= MASTERY_THRESHOLD) {
        tracker[lastIndex].cooldown = COOLDOWN_MASTERED;
        tracker[lastIndex].correctStreak = 0;
      }
      streak++;
      streakEl.textContent = String(streak);
      flameEl.classList.remove('hot');
      void flameEl.offsetWidth;
      flameEl.classList.add('hot');
      if (streak > 0 && streak % 10 === 0) {
        sessionStars++;
        updateStars();
        showToast('\u2B50', '#f59e0b');
        showPusheen(pusheenPopup);
      } else {
        showToast('Bravo', '#16a34a');
      }
      confetti();
      answer.style.borderColor = '#16a34a';
      answer.disabled = true;
      nextBtn.classList.remove('hidden');
      nextBtn.focus();
    } else {
      tracker[lastIndex].correctStreak = 0;
      tracker[lastIndex].cooldown = COOLDOWN_FAILED;
      if (streak > 0) saveBest('doubles', streak, sessionStars);
      streak = 0;
      sessionStars = 0;
      updateStars();
      streakEl.textContent = '0';
      showToast('Essaie encore', '#dc2626');
      answer.style.borderColor = '#dc2626';
      answer.value = '';
      answer.focus();
    }
  }

  numpad.forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = (btn as HTMLElement).dataset.key!;
      if (key === 'ok') {
        if (answer.disabled) { nextExercise(); } else { check(); }
      } else if (key === 'del') {
        answer.value = answer.value.slice(0, -1);
      } else if (!answer.disabled) {
        answer.value += key;
      }
    });
  });
  nextBtn.addEventListener('click', nextExercise);
  answer.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') check();
  });

  window.addEventListener('beforeunload', () => {
    if (streak > 0) saveBest('doubles', streak, sessionStars);
  });

  nextExercise();
</script>
