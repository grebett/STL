---
import Layout from '../layouts/Layout.astro';
---

<Layout title="L'exercice">
  <main>
    <a href={import.meta.env.BASE_URL} class="back">←</a>


    <div class="card">
      <div class="balance-equation">
        <span class="num left" id="val-left">7</span>
        <span class="op">+</span>
        <span class="num right" id="val-right">9</span>
      </div>
      <div class="double-badge" id="double-badge">&nbsp;</div>

      <div class="balance-scene">
        <div class="platform" id="lever">
          <div class="tray tray-left">
            <div class="balls" id="balls-left"></div>
          </div>
          <div class="beam"></div>
          <div class="tray tray-right">
            <div class="balls" id="balls-right"></div>
          </div>
        </div>
        <div class="fulcrum"></div>
      </div>

      <div class="slider-row">
        <button class="arrow-btn" id="btn-left">◀</button>
        <input type="range" id="slider" min="0" max="20" value="7" />
        <button class="arrow-btn" id="btn-right">▶</button>
      </div>

      <div class="problem">
        <span class="num left" id="orig-left">7</span>
        <span class="op">+</span>
        <span class="num right" id="orig-right">9</span>
        <span class="op">=</span>
        <input
          type="number"
          id="answer"
          inputmode="none"
          autocomplete="off"
          placeholder="?"
        />
      </div>

      <div class="numpad">
        <button class="numkey" data-key="1">1</button>
        <button class="numkey" data-key="2">2</button>
        <button class="numkey" data-key="3">3</button>
        <button class="numkey" data-key="4">4</button>
        <button class="numkey" data-key="5">5</button>
        <button class="numkey" data-key="6">6</button>
        <button class="numkey" data-key="7">7</button>
        <button class="numkey" data-key="8">8</button>
        <button class="numkey" data-key="9">9</button>
        <button class="numkey del" data-key="del">←</button>
        <button class="numkey" data-key="0">0</button>
        <button class="numkey ok" data-key="ok">OK</button>
      </div>

      <div class="status-bar">
        <div class="streak-col">
          <div class="streak-info">
            <span class="streak-flame" id="flame">🔥</span>
            <span class="streak-count" id="streak">0</span>
          </div>
          <div class="stars" id="stars"></div>
        </div>
        <button id="next" class="next-btn hidden">Suivant ▶</button>
      </div>

    </div>
  </main>
  <div class="toast" id="toast"></div>
  <div class="pusheen-popup" id="pusheen-popup"></div>
</Layout>

<style>
  main {
    text-align: center;
    padding: 1rem;
    width: 100%;
    max-width: 520px;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  .status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.4rem;
    min-height: 40px;
  }

  .streak-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }

  .streak-info {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #7c3aed;
  }

  .streak-flame {
    font-size: 1.4rem;
    transition: transform 0.3s;
  }

  .streak-flame.hot {
    animation: flame-pulse 0.5s ease;
  }

  @keyframes flame-pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.5); }
    100% { transform: scale(1); }
  }

  .streak-count {
    font-size: 1.4rem;
    min-width: 1.5ch;
  }

  .stars {
    font-size: 1.2rem;
    letter-spacing: 1px;
  }

  .card {
    background: white;
    border-radius: 1.5rem;
    padding: 1rem 1.2rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .problem {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-bottom: 0.3rem;
  }

  .problem .num {
    font-size: 2.2rem;
  }

  .problem .op {
    font-size: 2.2rem;
  }

  .balance-equation {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    margin-bottom: 0.1rem;
  }

  .num {
    font-size: 1.8rem;
    font-weight: 700;
    min-width: 2ch;
  }

  .num.left { color: #f472b6; }
  .num.right { color: #818cf8; }

  .num :global(ruby) { ruby-align: center; }
  .num :global(rt) { font-size: 0.35em; font-weight: 600; }
  .num :global(.rt-d) { color: #f59e0b; }
  .num :global(.rt-u) { color: #7c3aed; }

  .op {
    font-size: 1.8rem;
    color: #7c3aed;
    font-weight: 700;
  }

  .double-badge {
    font-size: 0.85rem;
    font-weight: 700;
    color: #16a34a;
    text-align: center;
    min-height: 1.2rem;
    transition: opacity 0.3s;
    opacity: 0;
  }

  .double-badge.visible {
    opacity: 1;
  }

  .balance-scene {
    position: relative;
    height: 100px;
    margin-bottom: 0.3rem;
  }

  .platform {
    position: absolute;
    left: 10%;
    right: 10%;
    bottom: 22px;
    height: 90px;
    transition: transform 0.4s ease;
    transform-origin: 50% calc(100% - 4px);
  }

  .beam {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 8px;
    background: linear-gradient(to bottom, #a78bfa, #7c3aed);
    border-radius: 4px;
  }

  .tray {
    position: absolute;
    bottom: 8px;
    width: 100px;
  }

  .tray-left { left: 0; }
  .tray-right { right: 0; }

  .balls {
    display: flex;
    flex-wrap: wrap-reverse;
    gap: 6px;
    justify-content: center;
  }

  .balls :global(.ball-group) {
    display: flex;
    gap: 2px;
  }

  .balls :global(.ball) {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    transition: all 0.25s ease;
  }

  .tray-left .balls :global(.ball) {
    background: #f472b6;
    box-shadow: inset -2px -2px 4px rgba(0,0,0,0.15), inset 2px 2px 4px rgba(255,255,255,0.3);
  }

  .tray-right .balls :global(.ball) {
    background: #818cf8;
    box-shadow: inset -2px -2px 4px rgba(0,0,0,0.15), inset 2px 2px 4px rgba(255,255,255,0.3);
  }

  .fulcrum {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 14px solid transparent;
    border-right: 14px solid transparent;
    border-bottom: 22px solid #7c3aed;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    justify-content: center;
    margin-bottom: 0.3rem;
  }

  .arrow-btn {
    font-size: 1rem;
    width: 34px;
    height: 34px;
    border: none;
    border-radius: 50%;
    background: #7c3aed;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, transform 0.1s;
  }

  .arrow-btn:hover { background: #6d28d9; }
  .arrow-btn:active { transform: scale(0.93); }

  input[type="range"] {
    flex: 1;
    max-width: 200px;
    height: 8px;
    -webkit-appearance: none;
    appearance: none;
    background: linear-gradient(to right, #f472b6, #818cf8);
    border-radius: 4px;
    outline: none;
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #7c3aed;
    cursor: pointer;
    border: 3px solid white;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  }

  input[type="number"] {
    font-size: 2.2rem;
    font-weight: 700;
    width: 3ch;
    text-align: center;
    border: 3px solid #e0e0e0;
    border-radius: 0.8rem;
    padding: 0;
    line-height: 1;
    vertical-align: middle;
    font-family: inherit;
    margin-top: 0.3rem;
    color: #1a1a2e;
    background: #fef7ff;
    outline: none;
    transition: border-color 0.2s;
  }

  input[type="number"]:focus {
    border-color: #7c3aed;
  }

  input[type="number"]::placeholder {
    color: #ccc;
  }

  input[type="number"]::-webkit-outer-spin-button,
  input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input[type="number"] {
    -moz-appearance: textfield;
  }

  .numpad {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
    max-width: 260px;
    margin: 0.6rem auto;
  }

  .numkey {
    font-size: 1.4rem;
    font-weight: 700;
    padding: 0.55rem;
    border: 2px solid #e0e0e0;
    border-radius: 0.8rem;
    background: #fef7ff;
    color: #1a1a2e;
    cursor: pointer;
    transition: background 0.1s, transform 0.1s;
  }

  .numkey:active {
    transform: scale(0.95);
    background: #ede9fe;
  }

  .numkey.del {
    background: #fee2e2;
    color: #dc2626;
    border-color: #fca5a5;
  }

  .numkey.ok {
    background: #7c3aed;
    color: white;
    border-color: #7c3aed;
  }

  .numkey.ok:active {
    background: #6d28d9;
  }

  .next-btn {
    font-size: 1.2rem;
    font-weight: 700;
    padding: 0.6rem 1.5rem;
    border: none;
    border-radius: 0.8rem;
    background: #16a34a;
    color: white;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }

  .next-btn:hover { background: #15803d; }
  .next-btn:active { transform: scale(0.97); }

  .hidden {
    visibility: hidden;
  }

  .toast {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    font-size: 4rem;
    font-weight: 900;
    padding: 0.6rem 2.5rem;
    border-radius: 1.5rem;
    pointer-events: none;
    z-index: 9998;
    opacity: 0;
    text-shadow: 0 4px 12px rgba(0,0,0,0.15);
    letter-spacing: 2px;
  }

  .toast.show {
    animation: toast-pop 1.8s cubic-bezier(.17,.67,.35,1.2) forwards;
  }

  @keyframes toast-pop {
    0% { transform: translate(-50%, -50%) scale(0) rotate(-8deg); opacity: 0; }
    12% { transform: translate(-50%, -50%) scale(1.4) rotate(3deg); opacity: 1; }
    20% { transform: translate(-50%, -50%) scale(0.9) rotate(-2deg); }
    28% { transform: translate(-50%, -50%) scale(1.15) rotate(1deg); }
    36% { transform: translate(-50%, -50%) scale(1) rotate(0deg); }
    70% { transform: translate(-50%, -50%) scale(1) rotate(0deg); opacity: 1; }
    100% { transform: translate(-50%, -70%) scale(1.3) rotate(0deg); opacity: 0; }
  }

  .pusheen-popup {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    z-index: 9997;
    pointer-events: none;
    opacity: 0;
    filter: drop-shadow(0 4px 20px rgba(124, 58, 237, 0.3));
  }

  .pusheen-popup :global(img) {
    max-height: 160px;
    border-radius: 1rem;
  }

  .pusheen-popup.show {
    animation: pusheen-pop 3s cubic-bezier(.17,.67,.35,1.2) forwards;
  }

  @keyframes pusheen-pop {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
    10% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
    18% { transform: translate(-50%, -50%) scale(0.95); }
    25% { transform: translate(-50%, -50%) scale(1); }
    75% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    100% { transform: translate(-50%, -60%) scale(0.8); opacity: 0; }
  }
</style>

<script>
  import { showPusheen } from '../pusheen';

  const pusheenPopup = document.getElementById('pusheen-popup')!;

  function confetti() {
    const colors = ['#f472b6', '#818cf8', '#7c3aed', '#16a34a', '#facc15', '#fb923c'];
    const count = 80;
    for (let i = 0; i < count; i++) {
      const el = document.createElement('div');
      const size = Math.random() * 8 + 4;
      el.style.cssText = `
        position:fixed;z-index:9999;pointer-events:none;
        width:${size}px;height:${size}px;
        background:${colors[Math.floor(Math.random() * colors.length)]};
        border-radius:${Math.random() > 0.5 ? '50%' : '2px'};
        left:${Math.random() * 100}vw;top:-10px;
        opacity:1;
      `;
      document.body.appendChild(el);
      const x = (Math.random() - 0.5) * 200;
      const y = Math.random() * 600 + 400;
      const r = Math.random() * 720 - 360;
      const dur = Math.random() * 1000 + 1500;
      el.animate([
        { transform: 'translate(0,0) rotate(0deg)', opacity: 1 },
        { opacity: 1, offset: 0.7 },
        { transform: `translate(${x}px,${y}px) rotate(${r}deg)`, opacity: 0 },
      ], { duration: dur, easing: 'cubic-bezier(.25,.46,.45,.94)' })
        .onfinish = () => el.remove();
    }
  }

  const problems = [
    [3, 5], [4, 6], [5, 7], [6, 8], [7, 9], [8, 10],
    [2, 4], [3, 7], [4, 8], [5, 9], [6, 10], [7, 11],
    [8, 12], [9, 11], [9, 13], [6, 14], [7, 13], [8, 14],
  ];

  const origLeft = document.getElementById('orig-left')!;
  const origRight = document.getElementById('orig-right')!;
  const valLeft = document.getElementById('val-left')!;
  const valRight = document.getElementById('val-right')!;
  const ballsLeft = document.getElementById('balls-left')!;
  const ballsRight = document.getElementById('balls-right')!;
  const lever = document.getElementById('lever')!;
  const slider = document.getElementById('slider') as HTMLInputElement;
  const btnLeft = document.getElementById('btn-left')!;
  const btnRight = document.getElementById('btn-right')!;
  const answerInput = document.getElementById('answer') as HTMLInputElement;
  const numpad = document.querySelectorAll('.numkey');
  const nextBtn = document.getElementById('next')!;
  const toast = document.getElementById('toast')!;

  function showToast(text: string, color: string) {
    toast.textContent = text;
    toast.style.color = color;
    toast.classList.remove('show');
    void toast.offsetWidth;
    toast.classList.add('show');
  }
  const doubleBadge = document.getElementById('double-badge')!;
  const streakEl = document.getElementById('streak')!;
  const starsEl = document.getElementById('stars')!;
  const flameEl = document.getElementById('flame')!;

  let total: number;
  let leftCount: number;
  let origA: number;
  let origB: number;
  let lastIndex = -1;
  let streak = 0;
  let sessionStars = 0;
  const COOLDOWN_MASTERED = 3;
  const COOLDOWN_FAILED = 1;
  const MASTERY_THRESHOLD = 3;
  const STALE_THRESHOLD = problems.length;
  const tracker = problems.map(() => ({ correctStreak: 0, cooldown: 0, lastSeen: 0 }));
  let pickCount = 0;

  function updateStars() {
    starsEl.textContent = Array(sessionStars).fill('\u2B50').join('');
  }

  function saveBest(game: string, streak: number, stars: number) {
    const data = JSON.parse(localStorage.getItem('maths-data') || '{}');
    if (!data[game]) data[game] = { bestStreak: 0, totalStars: 0, sessions: [] };
    const g = data[game];
    if (streak > g.bestStreak) g.bestStreak = streak;
    g.totalStars += stars;
    g.sessions.unshift({ streak, stars, date: new Date().toISOString() });
    if (g.sessions.length > 20) g.sessions.length = 20;
    localStorage.setItem('maths-data', JSON.stringify(data));
  }

  function renderNumber(el: HTMLElement, n: number) {
    if (n < 10) {
      el.innerHTML = `<ruby>${n}<rt class="rt-u">u</rt></ruby>`;
    } else {
      const d = Math.floor(n / 10);
      const u = n % 10;
      el.innerHTML = `<ruby>${d}<rt class="rt-d">d</rt></ruby><ruby>${u}<rt class="rt-u">u</rt></ruby>`;
    }
  }

  function renderBalls(container: HTMLElement, count: number) {
    container.innerHTML = '';
    const fullGroups = Math.floor(count / 5);
    const remainder = count % 5;
    for (let g = 0; g < fullGroups; g++) {
      const group = document.createElement('span');
      group.className = 'ball-group';
      for (let i = 0; i < 5; i++) {
        const ball = document.createElement('span');
        ball.className = 'ball';
        group.appendChild(ball);
      }
      container.appendChild(group);
    }
    if (remainder > 0) {
      const group = document.createElement('span');
      group.className = 'ball-group';
      for (let i = 0; i < remainder; i++) {
        const ball = document.createElement('span');
        ball.className = 'ball';
        group.appendChild(ball);
      }
      container.appendChild(group);
    }
  }

  function pickRandom() {
    pickCount++;
    let staleIdx = -1;
    let stalestAge = 0;
    for (let i = 0; i < problems.length; i++) {
      const age = pickCount - tracker[i].lastSeen;
      if (i !== lastIndex && age > STALE_THRESHOLD && age > stalestAge) {
        stalestAge = age;
        staleIdx = i;
      }
    }
    if (staleIdx !== -1) {
      tracker[staleIdx].cooldown = 0;
      lastIndex = staleIdx;
      tracker[staleIdx].lastSeen = pickCount;
      tracker.forEach(t => { if (t.cooldown > 0) t.cooldown--; });
      return problems[staleIdx];
    }
    let eligible = [];
    for (let i = 0; i < problems.length; i++) {
      if (tracker[i].cooldown === 0 && i !== lastIndex) eligible.push(i);
    }
    if (eligible.length === 0) {
      for (let i = 0; i < problems.length; i++) {
        if (i !== lastIndex) eligible.push(i);
      }
    }
    const idx = eligible[Math.floor(Math.random() * eligible.length)];
    lastIndex = idx;
    tracker[idx].lastSeen = pickCount;
    tracker.forEach(t => { if (t.cooldown > 0) t.cooldown--; });
    return problems[idx];
  }

  function updateBalance() {
    const rightCount = total - leftCount;

    renderNumber(valLeft, leftCount);
    renderNumber(valRight, rightCount);

    renderBalls(ballsLeft, leftCount);
    renderBalls(ballsRight, rightCount);

    slider.value = String(leftCount);

    const diff = leftCount - rightCount;
    const maxAngle = 15;
    const angle = -(diff / Math.max(total, 1)) * maxAngle;
    lever.style.transform = `rotate(${angle}deg)`;

    if (leftCount === rightCount) {
      doubleBadge.textContent = 'C\u2019est un double';
      doubleBadge.classList.add('visible');
    } else {
      doubleBadge.textContent = '\u00a0';
      doubleBadge.classList.remove('visible');
    }
  }

  function setInteractive(enabled: boolean) {
    slider.disabled = !enabled;
    (btnLeft as HTMLButtonElement).disabled = !enabled;
    (btnRight as HTMLButtonElement).disabled = !enabled;
    answerInput.disabled = !enabled;
  }

  function nextProblem() {
    const [a, b] = pickRandom();
    if (Math.random() > 0.5) {
      origA = b; origB = a;
    } else {
      origA = a; origB = b;
    }

    total = origA + origB;
    leftCount = origA;

    renderNumber(origLeft, origA);
    renderNumber(origRight, origB);

    slider.max = String(total);
    answerInput.value = '';
    answerInput.style.borderColor = '';
    setInteractive(true);
    nextBtn.classList.add('hidden');

    updateBalance();
    answerInput.focus();
  }

  function check() {
    const val = parseInt(answerInput.value, 10);
    if (isNaN(val)) {
      answerInput.focus();
      return;
    }

    if (val === total) {
      tracker[lastIndex].correctStreak++;
      if (tracker[lastIndex].correctStreak >= MASTERY_THRESHOLD) {
        tracker[lastIndex].cooldown = COOLDOWN_MASTERED;
        tracker[lastIndex].correctStreak = 0;
      }
      streak++;
      streakEl.textContent = String(streak);
      flameEl.classList.remove('hot');
      void flameEl.offsetWidth;
      flameEl.classList.add('hot');
      if (streak > 0 && streak % 10 === 0) {
        sessionStars++;
        updateStars();
        showToast('\u2B50', '#f59e0b');
        showPusheen(pusheenPopup);
      } else {
        showToast('Bravo', '#16a34a');
      }
      confetti();
      answerInput.style.borderColor = '#16a34a';
      setInteractive(false);
      nextBtn.classList.remove('hidden');
      nextBtn.focus();
    } else {
      tracker[lastIndex].correctStreak = 0;
      tracker[lastIndex].cooldown = COOLDOWN_FAILED;
      if (streak > 0) saveBest('exercice', streak, sessionStars);
      streak = 0;
      sessionStars = 0;
      updateStars();
      streakEl.textContent = '0';
      showToast('Essaie encore', '#dc2626');
      answerInput.style.borderColor = '#dc2626';
      answerInput.value = '';
      answerInput.focus();
    }
  }

  slider.addEventListener('input', () => {
    leftCount = parseInt(slider.value, 10);
    updateBalance();
  });

  btnLeft.addEventListener('click', () => {
    if (leftCount > 0) { leftCount--; updateBalance(); }
  });

  btnRight.addEventListener('click', () => {
    if (leftCount < total) { leftCount++; updateBalance(); }
  });

  numpad.forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = (btn as HTMLElement).dataset.key!;
      if (key === 'ok') {
        if (answerInput.disabled) { nextProblem(); } else { check(); }
      } else if (key === 'del') {
        answerInput.value = answerInput.value.slice(0, -1);
      } else if (!answerInput.disabled) {
        answerInput.value += key;
      }
    });
  });
  nextBtn.addEventListener('click', nextProblem);
  answerInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') check();
  });

  window.addEventListener('beforeunload', () => {
    if (streak > 0) saveBest('exercice', streak, sessionStars);
  });

  nextProblem();
</script>
